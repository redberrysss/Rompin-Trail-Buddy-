rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isFacilitator() {
      let role = firestore.get(
        /databases/(default)/documents/users/$(request.auth.uid)
      ).data.role;
      return isSignedIn() && role in [
        'facilitator', 'fasilitator', 'admin', 'teacher', 'guru',
        'therapist', 'terapis'
      ];
    }

    function isValidImage() {
      return request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    function isValidAudio() {
      return request.resource.size < 50 * 1024 * 1024
        && request.resource.contentType.matches('audio/.*');
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if isOwner(userId) || isFacilitator();
      allow create, update: if isOwner(userId)
        && (isValidImage() || isValidAudio());
      allow delete: if isOwner(userId);
    }
  }
}
